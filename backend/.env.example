# Backend Server Configuration
PORT=3000

# Oracle Database Configuration
# In Docker Compose, the database host matches the database service name: "oracle-db"
DB_USER=SYSTEM
DB_PASSWORD=<REDACTED>
DB_CONNECT_STRING=oracle-db:1521/FREEPDB1

# JWT Configuration
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<REDACTED>
JWT_EXPIRATION=8h

# Initial Super Admin (used ONLY on first boot when no superadmin exists)
SUPERADMIN_DNI=<REDACTED>
SUPERADMIN_INITIAL_PASSWORD=<REDACTED>
